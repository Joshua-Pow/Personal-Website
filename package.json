{
  "name": "website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "node scripts/generate-adages-manifest.mjs && next build",
    "dev": "node scripts/generate-adages-manifest.mjs && next dev --turbopack",
    "start": "next start",
    "lint": "node scripts/generate-adages-manifest.mjs && eslint src && tsc --noEmit",
    "prepare": "husky",
    "preview": "node scripts/generate-adages-manifest.mjs && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "node scripts/generate-adages-manifest.mjs && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "node scripts/sync-adage-images.mjs && node scripts/generate-adages-manifest.mjs && opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv worker-configuration.d.ts",
    "adages:upload": "node scripts/upload-adage-image.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@opennextjs/cloudflare": "^1.20.1",
    "@types/iso-3166-2": "^1.0.3",
    "@upstash/redis": "^1.35.3",
    "clsx": "^2.1.1",
    "cobe": "^0.6.3",
    "iso-3166-2": "^1.0.0",
    "motion": "^12.42.2",
    "next": "^16.2.10",
    "next-view-transitions": "^0.3.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "swr": "^2.3.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.0.7",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "postcss": "^8",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.2",
    "typescript": "^5",
    "wrangler": "^4.59.2"
  }
}
